<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#C8E6C9"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- IMAGEN DE LA PLANTA -->
        <ImageView
            android:id="@+id/imgCultivo"
            android:layout_width="90dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:background="#E8F5E9"
            android:padding="6dp" />

        <!-- CONTENIDO DERECHO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="14dp"
            android:paddingTop="12dp"   >

            <!-- NOMBRE PLANTA -->
            <TextView
                android:id="@+id/txtNombrePlanta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calabaza"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="4dp" />

            <!-- CANTIDAD Y FECHA -->
            <TextView
                android:id="@+id/txtCantidadCultivo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4 plantas"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/txtFechaSiembra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sembrado: 26/04/2026"
                android:textSize="11sp"
                android:textColor="#999999"
                android:layout_marginBottom="6dp" />

            <!-- ESTADO -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <ImageView
                    android:id="@+id/iconWarning"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/ic_dialog_alert"
                    android:layout_marginEnd="4dp"
                    android:visibility="gone"
                    app:tint="#E65100"
                    android:contentDescription="Cultivo enfermo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estado: "
                    android:textSize="12sp"
                    android:textColor="#666666" />

                <TextView
                    android:id="@+id/txtEstadoCultivo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#2E7D32" />
            </LinearLayout>

            <!-- NOTAS (visible solo si hay) -->
            <TextView
                android:id="@+id/txtNotasCultivo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFF9C4"
                android:padding="6dp"
                android:textSize="10sp"
                android:textColor="#856404"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- INCOMPATIBILIDADES (visible solo si hay conflictos) -->
            <TextView
                android:id="@+id/txtIncompatibilidades"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFEBEE"
                android:padding="6dp"
                android:text="⚠️ Hay plantas incompatibles en tu huerto"
                android:textSize="10sp"
                android:textColor="#C62828"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />


            <!-- BOTONES DE ACCIÓN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <!-- EDITAR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditarCultivo"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:text="Editar"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF9800"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="10dp"
                    app:iconGravity="textStart"
                    app:iconPadding="4dp"
                    style="@style/Widget.MaterialComponents.Button" />

                <!-- ELIMINAR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEliminarCultivo"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:text="Eliminar"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#C62828"
                    app:cornerRadius="10dp"
                    app:iconGravity="textStart"
                    app:iconPadding="4dp"
                    style="@style/Widget.MaterialComponents.Button" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>