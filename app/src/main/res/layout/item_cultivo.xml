<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#C8E6C9"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- IMAGEN DE LA PLANTA -->
        <ImageView
            android:id="@+id/imgCultivo"
            android:layout_width="110dp"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#E8F5E9"
            android:padding="8dp" />

        <!-- CONTENIDO DERECHO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- DATOS DE LA PLANTA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Necesidades de la planta"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:layout_marginBottom="10dp" />

                <!-- NOMBRE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Planta"
                        android:textColor="#555555"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtNombrePlanta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#1B5E20"
                        android:textStyle="bold"
                        android:textSize="13sp" />

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8F5E9"/>

                <!-- RIEGO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tipo de riego"
                        android:textColor="#555555"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtRiegoCultivo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#333333"
                        android:textStyle="bold"
                        android:textSize="13sp" />

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8F5E9"/>

                <!-- ABONO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Abono necesario"
                        android:textColor="#555555"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtAbonoCultivo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#333333"
                        android:textStyle="bold"
                        android:textSize="13sp" />

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8F5E9"/>

                <!-- TIEMPO CRECIMIENTO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tiempo de crecimiento"
                        android:textColor="#555555"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtTiempoCultivo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#333333"
                        android:textStyle="bold"
                        android:textSize="13sp" />

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8F5E9"/>

                <!-- ESTADO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Estado"
                        android:textColor="#555555"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtEstadoCultivo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- DIVISOR -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E8F5E9" />

            <!-- BOTONES DE ACCIÓN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="#F9FBF9">

                <!-- ELIMINAR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEliminarCultivo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="🗑 Eliminar"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#C62828"
                    app:cornerRadius="10dp"
                    style="@style/Widget.MaterialComponents.Button" />

                <!-- VER DETALLE PLANTA -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerCultivo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📖 Ver planta"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2E7D32"
                    app:cornerRadius="10dp"
                    style="@style/Widget.MaterialComponents.Button" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>