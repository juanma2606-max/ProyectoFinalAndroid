<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#C8E6C9"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- IMAGEN DE LA PLANTA -->
        <ImageView
            android:id="@+id/imgCultivo"
            android:layout_width="110dp"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#E8F5E9"
            android:padding="8dp" />

        <!-- CONTENIDO DERECHO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- HEADER: Nombre cultivo + warning -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:paddingBottom="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Nombre personalizado cultivo -->
                    <TextView
                        android:id="@+id/txtNombreCultivo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mi cultivo"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"
                        android:visibility="gone" />

                    <!-- Cantidad y fecha -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="2dp">

                        <TextView
                            android:id="@+id/txtCantidadCultivo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5 plantas"
                            android:textSize="11sp"
                            android:textColor="#666666" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" • "
                            android:textSize="11sp"
                            android:textColor="#666666" />

                        <TextView
                            android:id="@+id/txtFechaSiembra"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sembrado: 24/04/2026"
                            android:textSize="11sp"
                            android:textColor="#666666" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Warning icon si enfermo -->
                <ImageView
                    android:id="@+id/iconWarning"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_dialog_alert"
                    android:tint="#FFC107"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- DATOS DE LA PLANTA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Necesidades de la planta"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:layout_marginBottom="6dp" />

                <!-- NOMBRE PLANTA -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Planta"
                        android:textColor="#555555"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtNombrePlanta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#1B5E20"
                        android:textStyle="bold"
                        android:textSize="12sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E8F5E9" />

                <!-- RIEGO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tipo de riego"
                        android:textColor="#555555"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtRiegoCultivo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#333333"
                        android:textStyle="bold"
                        android:textSize="12sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E8F5E9" />

                <!-- ABONO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Abono necesario"
                        android:textColor="#555555"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtAbonoCultivo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#333333"
                        android:textStyle="bold"
                        android:textSize="12sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E8F5E9" />

                <!-- TIEMPO CRECIMIENTO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tiempo de crecimiento"
                        android:textColor="#555555"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtTiempoCultivo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#333333"
                        android:textStyle="bold"
                        android:textSize="12sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E8F5E9" />

                <!-- ESTADO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Estado"
                        android:textColor="#555555"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtEstadoCultivo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- NOTAS (visible solo si hay) -->
            <TextView
                android:id="@+id/txtNotasCultivo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFF9C4"
                android:padding="8dp"
                android:textSize="11sp"
                android:textColor="#856404"
                android:visibility="gone" />

            <!-- DIVISOR -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E8F5E9" />

            <!-- BOTONES DE ACCIÓN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="#F9FBF9">

                <!-- ELIMINAR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEliminarCultivo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="🗑 Eliminar"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#C62828"
                    app:cornerRadius="10dp"
                    style="@style/Widget.MaterialComponents.Button" />

                <!-- VER DETALLE PLANTA -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerCultivo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📖 Ver planta"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2E7D32"
                    app:cornerRadius="10dp"
                    style="@style/Widget.MaterialComponents.Button" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>