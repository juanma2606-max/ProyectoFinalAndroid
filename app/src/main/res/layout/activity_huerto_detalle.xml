<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B2A1B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- BARRA SUPERIOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:background="#2E7D32"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:gravity="center_vertical"
            android:elevation="4dp">

            <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:contentDescription="@string/volver"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/txtNombreHuerto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp" />

            <ImageButton
                android:id="@+id/btnEditarHuerto"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                app:tint="#FFFFFF"
                android:contentDescription="Editar huerto" />

        </LinearLayout>

        <!-- CONTENIDO SCROLLEABLE -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="80dp">

                <!-- IMAGEN DEL HUERTO -->
                <ImageView
                    android:id="@+id/imgHuertoDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:background="#1B3A1B"
                    android:contentDescription="@string/imagen_huerto" />

                <!-- CARD DESCRIPCIÓN - COLAPSABLE -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="14dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#263226">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- HEADER CLICKEABLE -->
                        <LinearLayout
                            android:id="@+id/headerDescripcion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/descripcion_huerto"
                                android:textColor="#A5D6A7"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/iconDescripcion"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/arrow_down_float"
                                android:contentDescription="Expandir descripción"
                                app:tint="#A5D6A7" />

                        </LinearLayout>

                        <!-- CONTENIDO COLAPSABLE -->
                        <LinearLayout
                            android:id="@+id/contentDescripcion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="16dp"
                            android:visibility="visible">

                            <TextView
                                android:id="@+id/txtDescripcionHuerto"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="#CCCCCC"
                                android:textSize="14sp"
                                android:lineSpacingExtra="4dp" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- CARD INFORMACIÓN DEL HUERTO - COLAPSABLE -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardInfoHuerto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#263226">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- HEADER CLICKEABLE -->
                        <LinearLayout
                            android:id="@+id/headerInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="ℹ️ Información del huerto"
                                android:textColor="#A5D6A7"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/iconInfo"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/arrow_down_float"
                                android:contentDescription="Expandir información"
                                app:tint="#A5D6A7" />

                        </LinearLayout>

                        <!-- CONTENIDO COLAPSABLE -->
                        <LinearLayout
                            android:id="@+id/contentInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="16dp"
                            android:visibility="gone">

                            <!-- Ubicación -->
                            <TextView
                                android:id="@+id/txtUbicacion"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="📍 Ubicación"
                                android:textColor="#CCCCCC"
                                android:textSize="14sp"
                                android:layout_marginBottom="8dp" />

                            <!-- Superficie -->
                            <TextView
                                android:id="@+id/txtSuperficie"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="📏 Superficie"
                                android:textColor="#CCCCCC"
                                android:textSize="14sp"
                                android:layout_marginBottom="8dp" />

                            <!-- Tipo de suelo -->
                            <TextView
                                android:id="@+id/txtTipoSuelo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="🌱 Tipo de suelo"
                                android:textColor="#CCCCCC"
                                android:textSize="14sp"
                                android:layout_marginBottom="8dp" />

                            <!-- Horas de sol -->
                            <TextView
                                android:id="@+id/txtHorasSol"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="☀️ Horas de sol"
                                android:textColor="#CCCCCC"
                                android:textSize="14sp"
                                android:layout_marginBottom="8dp" />

                            <!-- Riego -->
                            <TextView
                                android:id="@+id/txtRiego"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="💧 Riego"
                                android:textColor="#CCCCCC"
                                android:textSize="14sp" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- CARD NOTAS - COLAPSABLE (visible solo si hay notas) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardNotas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#3E5035"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- HEADER CLICKEABLE -->
                        <LinearLayout
                            android:id="@+id/headerNotas"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="📝 Notas"
                                android:textColor="#C5E1A5"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/iconNotas"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/arrow_down_float"
                                android:contentDescription="Expandir notas"
                                app:tint="#C5E1A5" />

                        </LinearLayout>

                        <!-- CONTENIDO COLAPSABLE -->
                        <LinearLayout
                            android:id="@+id/contentNotas"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="16dp"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/txtNotas"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="#E8F5E9"
                                android:textSize="14sp"
                                android:lineSpacingExtra="4dp" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- TÍTULO SECCIÓN CULTIVOS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/mis_plantaciones"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- ESTADO VACÍO CULTIVOS -->
                <LinearLayout
                    android:id="@+id/emptyStateCultivos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌱"
                        android:textSize="48sp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_plantaciones"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/instrucciones_agregar_planta"
                        android:textColor="#A5D6A7"
                        android:textSize="13sp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- LISTA DE CULTIVOS -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerCultivos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- FAB AGREGAR CULTIVO -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAgregarCultivo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Agregar cultivo"
        app:backgroundTint="#2E7D32"
        app:tint="#FFFFFF"
        app:elevation="6dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAnalizarHuerto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="20dp"
        android:text="Analizar con IA"
        android:backgroundTint="#FF9800"
        app:icon="@android:drawable/ic_menu_search"
        app:cornerRadius="24dp"
        android:textColor="#FFFFFF"
        app:iconTint="#FFFFFF"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
