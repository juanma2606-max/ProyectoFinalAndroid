<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardHuerto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#263226"
    app:strokeColor="#3A5A3A"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- IMAGEN -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="140dp">

            <ImageView
                android:id="@+id/imgHuerto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#1B3A1B" />

            <!-- Botones acción (esquina superior derecha) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:orientation="horizontal"
                android:padding="8dp">

                <!-- Editar -->
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnEditarHuerto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@android:drawable/ic_menu_edit"
                    app:fabCustomSize="40dp"
                    app:maxImageSize="20dp"
                    app:backgroundTint="#FFA726"
                    app:tint="#FFFFFF"
                    app:elevation="2dp"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Eliminar -->
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnEliminarHuerto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@android:drawable/ic_menu_delete"
                    app:fabCustomSize="40dp"
                    app:maxImageSize="20dp"
                    app:backgroundTint="#EF5350"
                    app:tint="#FFFFFF"
                    app:elevation="2dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </FrameLayout>

        <!-- CONTENIDO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- NOMBRE -->
            <TextView
                android:id="@+id/txtNombreHuerto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mi Huerto"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- DESCRIPCIÓN -->
            <TextView
                android:id="@+id/txtDescripcionHuerto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Descripción del huerto"
                android:textSize="13sp"
                android:textColor="#A5D6A7"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="4dp" />

            <!-- INFO ADICIONAL (grid) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <!-- Columna 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Ubicación -->
                    <TextView
                        android:id="@+id/txtUbicacionHuerto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 Sevilla"
                        android:textSize="11sp"
                        android:textColor="#81C784" />

                    <!-- Superficie -->
                    <TextView
                        android:id="@+id/txtSuperficieHuerto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📏 12.5 m²"
                        android:textSize="11sp"
                        android:textColor="#81C784"
                        android:layout_marginTop="4dp" />

                    <!-- Tipo suelo -->
                    <TextView
                        android:id="@+id/txtTipoSueloHuerto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌱 Franco"
                        android:textSize="11sp"
                        android:textColor="#81C784"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Columna 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Horas sol -->
                    <TextView
                        android:id="@+id/txtHorasSolHuerto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☀️ 6 horas/día"
                        android:textSize="11sp"
                        android:textColor="#81C784" />

                    <!-- Riego -->
                    <TextView
                        android:id="@+id/txtRiegoHuerto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💧 Manual"
                        android:textSize="11sp"
                        android:textColor="#81C784"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Hint visual para click -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toca para ver detalles ›"
            android:textSize="10sp"
            android:textColor="#66BB6A"
            android:gravity="center"
            android:paddingBottom="8dp"
            android:alpha="0.7" />

    </LinearLayout>

    <!-- Botón Ver (invisible pero funciona con click en card) -->
    <View
        android:id="@+id/btnVerHuerto"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</com.google.android.material.card.MaterialCardView>