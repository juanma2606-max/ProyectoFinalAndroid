<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#C8E6C9"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- IMAGEN -->
        <ImageView
            android:id="@+id/imgPlanta"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:background="#E8F5E9"
            android:src="@drawable/ic_planta_placeholder"
            android:padding="6dp"
            android:contentDescription="Imagen de la planta" />

        <!-- CONTENIDO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- NOMBRE -->
            <TextView
                android:id="@+id/txtAdminNombrePlanta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lechuga"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B5E20" />

            <!-- TIPO -->
            <TextView
                android:id="@+id/txtAdminTipoPlanta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hortaliza"
                android:textSize="11sp"
                android:textColor="#999999"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- BOTONES -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminEditarPlanta"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Editar"
            android:textSize="12sp"
            android:backgroundTint="#FF9800"
            android:layout_marginEnd="6dp"
            android:layout_gravity="center_vertical"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminEliminarPlanta"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Eliminar"
            android:textSize="12sp"
            android:backgroundTint="#B71C1C"
            android:layout_gravity="center_vertical"
            app:cornerRadius="8dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>