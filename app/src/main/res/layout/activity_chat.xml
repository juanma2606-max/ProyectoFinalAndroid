<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1B2A1B">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2E4A2E"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <androidx.cardview.widget.CardView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="12dp"
            app:cardBackgroundColor="#81C784"
            app:cardCornerRadius="25dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_dialog_info"
                android:tint="#FFFFFF" />

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HuertingIA"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟢 En línea"
                android:textColor="#A5D6A7"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- MENSAJES -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMensajes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#E8F5E9"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- PREVIEW DE IMAGEN ADJUNTA -->
    <LinearLayout
        android:id="@+id/layoutPreviewImagen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2E4A2E"
        android:padding="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <ImageView
            android:id="@+id/imgPreviewChat"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleType="centerCrop"
            android:background="#1B2A1B"
            android:contentDescription="Vista previa de imagen" />

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Imagen adjunta"
            android:textColor="#A5D6A7"
            android:textSize="13sp"
            android:layout_marginStart="8dp" />

        <ImageButton
            android:id="@+id/btnQuitarImagen"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#EF9A9A"
            android:contentDescription="Quitar imagen" />

    </LinearLayout>

    <!-- INPUT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2E4A2E"
        android:padding="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <ImageButton
            android:id="@+id/btnAdjuntarImagen"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#A5D6A7"
            android:layout_marginEnd="4dp"
            android:contentDescription="Adjuntar imagen" />

        <EditText
            android:id="@+id/etMensaje"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="Escribe tu pregunta..."
            android:textColorHint="#81C784"
            android:textColor="#212121"
            android:textSize="15sp"
            android:background="@android:color/white"
            android:padding="12dp"
            android:minLines="1"
            android:maxLines="5"
            android:scrollbars="vertical"
            android:inputType="textMultiLine|textCapSentences"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnEnviar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="▶"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32" />

    </LinearLayout>

</LinearLayout>