<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7F0">

    <!-- CABECERA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2E7D32"
        android:padding="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌿 Plantas"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- FILTROS -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:elevation="2dp"
        android:scrollbars="none">

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <com.google.android.material.chip.Chip
                android:id="@+id/btnTodas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌱 Todas"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnHortaliza"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥕 Hortalizas"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnFruta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍎 Frutas"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnHierba"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿 Hierbas"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnFlor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌸 Flores"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnArbol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌳 Árboles"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- LISTA -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPlantas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:clipToPadding="false" />

</LinearLayout>