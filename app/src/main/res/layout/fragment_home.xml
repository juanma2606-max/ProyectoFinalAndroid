<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B2A1B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- CABECERA — equivalente al HEADER del html -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1B2A1B"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="20dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mis Huertos"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gestiona tus huertos y macetas de un vistazo"
                android:textColor="#A5D6A7"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:gravity="center" />

        </LinearLayout>

        <!-- LOADING — equivalente al ng-template #loading -->
        <LinearLayout
            android:id="@+id/layoutLoading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="48dp"
            android:paddingBottom="24dp"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:indeterminateTint="#4CAF50"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cargando tus huertos..."
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Un momento, por favor"
                android:textColor="#A5D6A7"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- ESTADO VACÍO — equivalente al bloque *ngIf="huertos.length === 0" -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="40dp"
            android:paddingBottom="32dp"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#263226">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <!-- Icono — equivalente a fa-seedling -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌱"
                        android:textSize="64sp"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¡Tu huerto está vacío!"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Aún no has registrado ningún huerto o maceta.\n¡Comienza a cultivar creando tu primer espacio verde!"
                        android:textSize="14sp"
                        android:textColor="#A5D6A7"
                        android:gravity="center"
                        android:layout_marginBottom="24dp" />

                    <!-- Botón crear — equivalente al btn-success del empty state -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCrearPrimerHuerto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ Crear mi primer huerto"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2E7D32"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        app:cornerRadius="12dp"
                        style="@style/Widget.MaterialComponents.Button" />

                    <!-- Divisor -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#3A4A3A"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="16dp" />

                    <!-- Tip — equivalente al fa-lightbulb -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡 ¿Sabías que puedes tener tanto parcelas como macetas?"
                        android:textSize="13sp"
                        android:textColor="#A5D6A7"
                        android:gravity="center" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- LISTA DE HUERTOS — equivalente al *ngFor con app-home-resume -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerHuertos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="14dp"
            android:clipToPadding="false"
            android:visibility="gone" />

    </LinearLayout>

    <!-- FAB AGREGAR — equivalente al botón Añadir nueva planta -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAgregarHuerto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Agregar huerto"
        app:backgroundTint="#2E7D32"
        app:tint="#FFFFFF"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>