<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B2A1B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER DECORATIVO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#2E4A2E"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌱"
                android:textSize="72sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Añadir cultivo"
                android:textColor="#A5D6A7"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elige la planta que vas a cultivar"
                android:textColor="#81C784"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- FORMULARIO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="#F8F9FA">

            <!-- SELECTOR DE PLANTA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Planta"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selecciona la planta que vas a cultivar"
                android:textColor="#666666"
                android:textSize="12sp"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPlantas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:nestedScrollingEnabled="false" />

            <!-- NOMBRE CULTIVO (OPCIONAL) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del cultivo"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="15sp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="#2E7D32"
                app:hintTextColor="#2E7D32"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNombreCultivo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ej: Tomates del balcón (opcional)"
                    android:inputType="text" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- CANTIDAD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cantidad de plantas"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="15sp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="#2E7D32"
                app:hintTextColor="#2E7D32"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCantidad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="¿Cuántas plantas?"
                    android:inputType="number"
                    android:text="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- FECHA SIEMBRA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha de siembra"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="15sp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="#2E7D32"
                app:hintTextColor="#2E7D32"
                app:endIconMode="custom"
                app:endIconDrawable="@android:drawable/ic_menu_my_calendar"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFechaSiembra"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Selecciona la fecha"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ESTADO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado inicial"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rgEstado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/rbPlantado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌱 Plantado"
                    android:checked="true"
                    android:textColor="#6C757D"
                    android:buttonTint="#6C757D"
                    android:padding="12dp" />

                <RadioButton
                    android:id="@+id/rbCreciendo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌿 Creciendo"
                    android:textColor="#0DCAF0"
                    android:buttonTint="#0DCAF0"
                    android:padding="12dp" />

                <RadioButton
                    android:id="@+id/rbMaduro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✅ Maduro"
                    android:textColor="#198754"
                    android:buttonTint="#198754"
                    android:padding="12dp" />

                <RadioButton
                    android:id="@+id/rbCosechado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📦 Cosechado"
                    android:textColor="#212529"
                    android:buttonTint="#212529"
                    android:padding="12dp" />

                <RadioButton
                    android:id="@+id/rbEnfermo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Enfermo"
                    android:textColor="#FFC107"
                    android:buttonTint="#FFC107"
                    android:padding="12dp" />

            </RadioGroup>

            <!-- SELECTOR AMENAZAS (visible solo si enfermo) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAmenazas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFF3CD"
                app:strokeColor="#FFC107"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️ Amenaza detectada"
                        android:textStyle="bold"
                        android:textColor="#856404"
                        android:textSize="15sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selecciona la plaga o enfermedad"
                        android:textColor="#856404"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp" />

                    <Spinner
                        android:id="@+id/spinnerAmenazas"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@android:drawable/btn_dropdown"
                        android:padding="12dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- NOTAS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notas"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="15sp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:boxStrokeColor="#2E7D32"
                app:hintTextColor="#2E7D32"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNotas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Observaciones (opcional)"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:maxLines="5"
                    android:gravity="top" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- BOTÓN GUARDAR -->
            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Añadir cultivo"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:backgroundTint="#2E7D32"
                android:layout_marginBottom="12dp" />

            <!-- BOTÓN CANCELAR -->
            <Button
                android:id="@+id/btnCancelar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Cancelar"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:textSize="16sp"
                android:backgroundTint="@android:color/transparent"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#2E7D32"
                app:strokeWidth="2dp" />

        </LinearLayout>

        <!-- HINT FINAL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Podrás cambiar el estado del cultivo en cualquier momento"
            android:textColor="#A5D6A7"
            android:textSize="12sp"
            android:gravity="center"
            android:padding="16dp"
            android:background="#1B2A1B" />

    </LinearLayout>
</ScrollView>