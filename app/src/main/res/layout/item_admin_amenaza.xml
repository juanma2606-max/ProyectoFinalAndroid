<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="10dp"
    app:cardBackgroundColor="#263226">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- IMAGEN AMENAZA -->
        <ImageView
            android:id="@+id/imgAmenaza"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="centerCrop"
            android:background="#3A1A1A"
            android:src="@drawable/ic_planta_placeholder"
            android:contentDescription="Imagen de la amenaza" />

        <!-- CONTENIDO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/txtAdminNombreAmenaza"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAdminTipoAmenaza"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#EF9A9A"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- BOTONES -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminEditarAmenaza"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Editar"
            android:textSize="12sp"
            android:backgroundTint="#FF9800"
            android:layout_marginEnd="6dp"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminEliminarAmenaza"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Eliminar"
            android:textSize="12sp"
            android:backgroundTint="#B71C1C"
            app:cornerRadius="8dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>