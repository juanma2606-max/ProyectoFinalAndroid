<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF8F8">

    <!-- BARRA SUPERIOR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:background="#2E7D32"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="24dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnVolver"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detalle de amenaza"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- CONTENIDO SCROLLEABLE -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- IMAGEN -->
            <ImageView
                android:id="@+id/imgAmenazaDetalle"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:background="#FFEBEE"
                android:layout_marginBottom="16dp" />

            <!-- NOMBRE -->
            <TextView
                android:id="@+id/txtNombreAmenaza"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#B71C1C"
                android:layout_marginBottom="8dp" />

            <!-- BADGE TIPO -->
            <TextView
                android:id="@+id/txtTipoBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp" />

            <!-- DESCRIPCIÓN -->
            <TextView
                android:id="@+id/txtDescripcionAmenaza"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#555555"
                android:textSize="16sp"
                android:layout_marginBottom="16dp" />

            <!-- DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#FFCDD2"
                android:layout_marginBottom="16dp" />

            <!-- SÍNTOMAS LABEL -->
            <TextView
                android:id="@+id/lblSintomas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔍 Síntomas"
                android:textStyle="bold"
                android:textColor="#E65100"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <!-- SÍNTOMAS LISTA -->
            <LinearLayout
                android:id="@+id/listSintomas"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <!-- TRATAMIENTO LABEL -->
            <TextView
                android:id="@+id/lblTratamiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💊 Tratamiento"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <!-- TRATAMIENTO TEXTO -->
            <TextView
                android:id="@+id/txtTratamiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#388E3C"
                android:textSize="15sp"
                android:paddingBottom="24dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>