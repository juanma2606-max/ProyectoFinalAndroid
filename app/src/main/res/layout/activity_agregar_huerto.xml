<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B2A1B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="20dp"
        android:paddingTop="40dp"
        android:orientation="vertical">

        <!-- BOTÓN VOLVER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                app:tint="#A5D6A7"
                android:contentDescription="Volver" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="6dp"
                android:text="Volver"
                android:textColor="#A5D6A7"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- CARD PRINCIPAL -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- COLUMNA IZQUIERDA — imagen decorativa -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="#2E4A2E"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌿"
                        android:textSize="72sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nuevo\nHuerto"
                        android:textColor="#A5D6A7"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Crea tu espacio\nverde personal"
                        android:textColor="#81C784"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

                <!-- COLUMNA DERECHA — formulario -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="#F8F9FA">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Crear huerto"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:gravity="center"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Completa los campos para continuar"
                        android:textColor="#777777"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:paddingBottom="20dp" />

                    <!-- NOMBRE -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:boxStrokeColor="#2E7D32"
                        app:hintTextColor="#2E7D32"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNombreHuerto"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Mi huerto"
                            android:inputType="textCapSentences"
                            android:maxLines="1" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- DESCRIPCIÓN -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Descripción"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="18dp"
                        app:boxStrokeColor="#2E7D32"
                        app:hintTextColor="#2E7D32"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDescripcionHuerto"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Opcional"
                            android:inputType="textMultiLine"
                            android:minLines="2"
                            android:maxLines="3"
                            android:gravity="top" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- TIPO -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipo de huerto"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupTipo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true"
                        android:layout_marginBottom="24dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipParcela"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌱 Parcela"
                            android:checked="true"
                            app:chipBackgroundColor="#E8F5E9"
                            app:chipStrokeColor="#2E7D32"
                            app:chipStrokeWidth="1dp"
                            style="@style/Widget.MaterialComponents.Chip.Choice" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMaceta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🪴 Maceta"
                            app:chipBackgroundColor="#E8F5E9"
                            app:chipStrokeColor="#2E7D32"
                            app:chipStrokeWidth="1dp"
                            style="@style/Widget.MaterialComponents.Chip.Choice" />

                    </com.google.android.material.chip.ChipGroup>

                    <!-- BOTÓN GUARDAR -->
                    <Button
                        android:id="@+id/btnGuardar"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Crear huerto"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2E7D32"
                        android:layout_marginBottom="10dp" />

                    <!-- BOTÓN CANCELAR -->
                    <Button
                        android:id="@+id/btnCancelar"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Cancelar"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:backgroundTint="@android:color/transparent"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="#2E7D32"
                        app:strokeWidth="1dp" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>