<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configuración"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="32dp"/>

        <!-- TARJETA DE USUARIO -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mi cuenta"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:layout_marginBottom="14dp"/>

                <!-- FOTO PERFIL -->
                <ImageView
                    android:id="@+id/imgPerfil"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_myplaces" />

                <!-- NOMBRE USUARIO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤  "
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/txtUsuarioNombre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cargando..."
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#333333"/>
                </LinearLayout>

                <!-- EMAIL -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✉️  "
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/txtUsuarioEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cargando..."
                        android:textSize="14sp"
                        android:textColor="#666666"/>
                </LinearLayout>

                <!-- PROVEEDOR AUTH -->
                <TextView
                    android:id="@+id/txtProveedorAuth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Autenticación: Cargando..."
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"/>

                <!-- BOTÓN EDITAR NOMBRE -->
                <Button
                    android:id="@+id/btnEditarNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Editar nombre"
                    android:textColor="#2E7D32"
                    android:backgroundTint="@android:color/transparent"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_marginBottom="8dp"/>

                <!-- BOTÓN CAMBIAR FOTO -->
                <Button
                    android:id="@+id/btnCambiarFoto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cambiar foto de perfil"
                    android:textColor="#2E7D32"
                    android:backgroundTint="@android:color/transparent"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_marginBottom="8dp"/>

                <!-- BOTÓN CAMBIAR CONTRASEÑA (solo Email) -->
                <Button
                    android:id="@+id/btnCambiarPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cambiar contraseña"
                    android:textColor="#2E7D32"
                    android:backgroundTint="@android:color/transparent"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:visibility="gone"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BOTÓN LOGOUT -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:text="Cerrar sesión"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#C62828"/>

    </LinearLayout>
</ScrollView>