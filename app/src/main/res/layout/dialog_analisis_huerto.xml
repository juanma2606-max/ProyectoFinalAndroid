<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2E7D32"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="🌱"
            android:textSize="32sp"
            android:gravity="center"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/txtTituloAnalisis"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Análisis de tu huerto"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- CONTENIDO CON ALTURA FIJA -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:padding="20dp">

        <!-- LOADING -->
        <LinearLayout
            android:id="@+id/layoutLoading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:id="@+id/progressAnalisis"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="#2E7D32" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Analizando tu huerto..."
                android:textColor="#666666"
                android:textSize="14sp"
                android:layout_marginTop="16dp" />

        </LinearLayout>

        <!-- RESULTADO EN SCROLLVIEW -->
        <ScrollView
            android:id="@+id/scrollAnalisis"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <TextView
                android:id="@+id/txtAnalisis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aquí aparecerá el análisis"
                android:textColor="#212121"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

        </ScrollView>

    </FrameLayout>

    <!-- BOTONES -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="end">

        <Button
            android:id="@+id/btnCerrar"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Cerrar"
            android:textColor="#666666"
            android:backgroundTint="@android:color/transparent"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#CCCCCC"
            app:strokeWidth="1dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnContinuarChat"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="💬 Chat"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

    </LinearLayout>

</LinearLayout>