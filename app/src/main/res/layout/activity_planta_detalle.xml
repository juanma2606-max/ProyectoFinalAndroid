<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- BARRA SUPERIOR CON BOTÓN VOLVER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#2E7D32"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnVolver"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#FFFFFF"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/volver" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/detalle_planta"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- CONTENIDO SCROLLEABLE -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- IMAGEN PRINCIPAL -->
            <ImageView
                android:id="@+id/imgPlantaDetalle"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:background="#EEEEEE"
                android:layout_marginBottom="16dp"
                android:contentDescription="@string/imagen_planta" />

            <!-- NOMBRE -->
            <TextView
                android:id="@+id/txtNombreDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:layout_marginBottom="8dp" />

            <!-- DESCRIPCIÓN -->
            <TextView
                android:id="@+id/txtDescripcionDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#555555"
                android:textSize="16sp"
                android:layout_marginBottom="16dp" />

            <!-- SECCIÓN NECESIDADES -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/necesidades_caracteristicas"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:textSize="18sp"
                android:layout_marginBottom="12dp" />

            <TextView android:id="@+id/txtEstacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <TextView android:id="@+id/txtAbono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <TextView android:id="@+id/txtRiego"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <TextView android:id="@+id/txtTiempo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#333333"
                android:layout_marginBottom="16dp"/>

            <!-- SECCIÓN INCOMPATIBILIDADES -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/incompatibilidades"
                android:textStyle="bold"
                android:textColor="#D68910"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/listIncompatibilidades"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <!-- SECCIÓN PLAGAS -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/plagas_enfermedades"
                android:textStyle="bold"
                android:textColor="#C0392B"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/listPlagas"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="24dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>